msgstr "Khóa ngay lập tức tên người dùng không hợp lệ"

#: templates/wp-admin/user-security/login-lockout.php:78
msgid "Enable this if you want to show a generic error message when a login attempt fails"
msgstr "Bật tính năng này nếu bạn muốn hiển thị một thông báo lỗi chung khi quá trình đăng nhập thất bại"

#: templates/wp-admin/user-security/login-lockout.php:75
msgid "Display generic error message"
msgstr "Hiển thị thông báo lỗi chung"

