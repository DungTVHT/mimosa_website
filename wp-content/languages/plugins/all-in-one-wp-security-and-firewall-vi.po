#: templates/wp-admin/user-security/login-lockout.php:86
msgid "Enable this if you want to instantly lockout login attempts with usernames which do not exist on your system"
msgstr "Bật tính năng này nếu bạn muốn khóa ngay lập tức các lần đăng nhập với tên người dùng không tồn tại trên hệ thống của bạn"

#: templates/wp-admin/user-security/login-lockout.php:83
