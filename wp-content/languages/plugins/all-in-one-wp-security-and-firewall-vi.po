#: templates/wp-admin/spam-prevention/comment-spam.php:47
msgid "This feature uses cookies."
msgstr "Tính năng này sử dụng cookie."

#: templates/wp-admin/spam-prevention/comment-spam.php:43
msgid "Using cookies may prevent caches from caching pages containing comment forms."
