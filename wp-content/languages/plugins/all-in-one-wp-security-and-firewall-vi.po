#: templates/wp-admin/firewall/6g.php:74
msgid "This setting will implement the 5G security firewall protection mechanisms on your site which include the following things:"
msgstr "Cài đặt này sẽ triển khai các cơ chế bảo vệ tường lửa bảo mật 5G trên trang web của bạn, bao gồm các điều sau:"

#: templates/wp-admin/firewall/6g.php:70
msgid "Enable this to apply the 5G firewall protection from perishablepress.com to your site."
msgstr "Bật tính năng này để áp dụng bảo vệ tường lửa 5G từ perishablepress.com cho trang web của bạn."

#: templates/wp-admin/firewall/6g.php:67
msgid "Enable legacy 5G firewall protection"
msgstr "Bật bảo vệ tường lửa 5G cũ"

#: templates/wp-admin/firewall/6g.php:37 templates/wp-admin/firewall/6g.php:79
msgid "....and much more."
msgstr "....và nhiều hơn nữa."

#: templates/wp-admin/firewall/6g.php:36 templates/wp-admin/firewall/6g.php:78
msgid "4) Stop attackers from manipulating query strings by disallowing illicit characters."
msgstr "4) Ngăn chặn kẻ tấn công thao túng chuỗi truy vấn bằng cách không cho phép các ký tự bất hợp pháp."

#: templates/wp-admin/firewall/6g.php:35 templates/wp-admin/firewall/6g.php:77
msgid "3) Guard against the common patterns and specific exploits in the root portion of targeted URLs."
msgstr "3) Bảo vệ chống lại các mẫu phổ biến và các lỗ hổng cụ thể trong phần gốc của URL bị nhắm mục tiêu."

#: templates/wp-admin/firewall/6g.php:34 templates/wp-admin/firewall/6g.php:76
msgid "2) Block malicious encoded URL characters such as the \".css(\" string."
msgstr "2) Chặn các ký tự URL được mã hóa độc hại như chuỗi \".css(\""

#: templates/wp-admin/firewall/6g.php:33 templates/wp-admin/firewall/6g.php:75
msgid "1) Block forbidden characters commonly used in exploitative attacks."
msgstr "1) Chặn các ký tự bị cấm thường được sử dụng trong các cuộc tấn công khai thác."

#: templates/wp-admin/firewall/6g.php:32
msgid "This setting will implement the 6G security firewall protection mechanisms on your site which include the following things:"
msgstr "Cài đặt này sẽ triển khai các cơ chế bảo vệ tường lửa bảo mật 6G trên trang web của bạn, bao gồm các điều sau:"

#: templates/wp-admin/firewall/6g.php:25
msgid "Enable 6G firewall protection"
msgstr "Bật bảo vệ tường lửa 6G"

#: templates/wp-admin/firewall/6g.php:7
msgid "The 6G firewall is a simple, flexible blacklist that helps reduce the number of malicious URL requests that hit your website."
msgstr "Tường lửa 6G là danh sách đen đơn giản, linh hoạt giúp giảm số lượng yêu cầu URL độc hại đến trang web của bạn."

#: templates/wp-admin/firewall/6g.php:5
msgid "This feature allows you to activate the %s (or legacy %s) firewall security protection rules designed and produced by %s."
msgstr "Tính năng này cho phép bạn kích hoạt các quy tắc bảo vệ tường lửa %s (hoặc %s cũ) được thiết kế và sản xuất bởi %s."

#: templates/wp-admin/firewall/partials/advanced-character-filter.php:24
msgid "NOTE: Some strings for this setting might break some functionality."
msgstr "LƯU Ý: Một số chuỗi cho cài đặt này có thể làm hỏng một số chức năng."

#: templates/wp-admin/firewall/partials/advanced-character-filter.php:23
msgid "This setting matches for common malicious string patterns and exploits and will produce a 403 error for the hacker attempting the query."
msgstr "Cài đặt này khớp với các mẫu chuỗi độc hại và lỗ hổng phổ biến và sẽ tạo ra lỗi 403 cho tin tặc đang cố gắng truy vấn."

#: templates/wp-admin/firewall/partials/advanced-character-filter.php:22
msgid "This is an advanced character string filter to prevent malicious string attacks on your site coming from Cross Site Scripting (XSS)."
msgstr "Đây là bộ lọc chuỗi ký tự nâng cao để ngăn chặn các cuộc tấn công chuỗi độc hại vào trang web của bạn từ Cross Site Scripting (XSS)."

#: templates/wp-admin/firewall/partials/advanced-character-filter.php:14
msgid "Enable advanced character string filter"
msgstr "Bật bộ lọc chuỗi ký tự nâng cao"

#: classes/grade-system/wp-security-feature-item-manager.php:253
#: templates/wp-admin/firewall/partials/advanced-character-filter.php:3
msgid "Advanced character string filter"
msgstr "Bộ lọc chuỗi ký tự nâng cao"

#: templates/wp-admin/firewall/partials/bad-query-strings.php:23
msgid "NOTE: Some of these strings might be used for plugins or themes and hence this might break some functionality."
msgstr "LƯU Ý: Một số chuỗi này có thể được sử dụng cho plugin hoặc theme và do đó điều này có thể làm hỏng một số chức năng."

#: templates/wp-admin/firewall/partials/bad-query-strings.php:17
msgid "This will help protect you against malicious queries via XSS."
msgstr "Điều này sẽ giúp bảo vệ bạn khỏi các truy vấn độc hại thông qua XSS."

#: classes/wp-security-notices.php:68
#: templates/wp-admin/firewall/partials/bad-query-strings.php:14
